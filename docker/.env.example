# ===========================================
# Docker Compose - copy ke .env dan sesuaikan
# cp .env.example .env
# ===========================================

# ---------- Compose / Infra ----------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=admin
POSTGRES_DB=web_auto
POSTGRES_PORT=5432

DATABASE_URL=postgresql://postgres:admin@postgres:5432/web_auto

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_PASS=guest
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672

CLIENT_PORT=3000
SCRAPER_PORT=3001
BUILDER_PORT=3002

# ---------- Client (Next.js) ----------
NODE_ENV=production
NEXT_PUBLIC_APP_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=

# Panggilan ke Scraper (pakai hostname 'scraper' di dalam Docker)
SCRAPER_URL=http://scraper:3001
API_KEY=

# Auth (Better Auth)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI (client / generate)
AI_GATEWAY_API_KEY=
GOOGLE_API_KEY=

# Opsional
IP_SERVER=
RABBITMQ_QUEUE_NAME=build_website

# ---------- Builder ----------
ROOT_BUILD_PATH=/app/builds
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_EMAIL=admin@localhost

# ---------- Scraper ----------
HOST=0.0.0.0
PROD_HOST=
CDN_BASE_URL=
AI_PROVIDER=chatgpt
DEBUG_PORT=9222
JWT_SECRET=
CONTENT_DIR=/app/content/images
RATE_LIMIT_WHITELIST=http://localhost:3000

# ---------- Cloudflare R2 (client, builder, scraper) ----------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=automate
R2_REGION=auto
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_PUBLIC_DOMAIN=https://your-cdn-domain.com
