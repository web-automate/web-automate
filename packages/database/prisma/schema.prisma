//
// Autogenerated by `prisma-import`
// Any modifications will be overwritten on subsequent runs.
//

//
// base.prisma
//

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//
// account.prisma
//

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([providerId, accountId])
  @@map("account")
}

//
// ai.prisma
//

model AiConfiguration {
  id        String   @id @default(cuid())
  provider  String   @unique // Contoh: 'anthropic', 'openai', 'gemini'
  apiKey    String // Simpan encrypted jika memungkinkan
  baseUrl   String? // Untuk provider yang menggunakan custom endpoint/proxy
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ai_configurations")
}

//
// article.prisma
//

model Article {
  id            String        @id @default(cuid())
  topic         String
  keywords      String[]
  category      String
  subCategory   String?
  title         String?
  slug          String?
  excerpt       String?       @db.Text
  content       String?       @db.Text
  featuredImage String?
  status        ArticleStatus @default(DRAFT)
  publishedAt   DateTime?

  // SEO Relation (1-to-1)
  seo ArticleSeo?

  websiteId   String
  website     Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  authorId    String
  author      Author   @relation(fields: [authorId], references: [id])
  createdById String?
  createdBy   User?    @relation("ArticleCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([websiteId, slug])
  @@index([websiteId])
  @@index([authorId])
  @@index([publishedAt])
}

//
// articleseo.prisma
//

model ArticleSeo {
  id String @id @default(cuid())

  // --- Primary Meta Tags ---
  metaTitle       String? // <meta name="title">
  metaDescription String?     @db.Text
  keywords        String[] // PostgreSQL array support
  author          String? // <meta name="author">
  language        String?     @default("English")
  robots          RobotsValue @default(index_follow)
  canonicalUrl    String? // <link rel="canonical">

  // --- Open Graph / Facebook ---
  ogTitle         String?
  ogDescription   String?   @db.Text
  ogImage         String?
  ogUrl           String?
  ogSiteName      String? // <meta property="og:site_name">
  ogType          OgType    @default(article)
  ogPublishedTime DateTime? // <meta property="article:published_time">
  ogAuthor        String? // <meta property="article:author">

  // --- Twitter Cards ---
  twitterCard        TwitterCard @default(summary_large_image)
  twitterTitle       String?
  twitterDescription String?     @db.Text
  twitterImage       String?
  twitterCreator     String? // <meta name="twitter:creator"> (e.g., @username)
  twitterUrl         String?

  // --- Structured Data (JSON-LD) ---
  /// Digunakan untuk menyimpan skema Article dari schema.org
  structuredData Json?

  // --- Relations ---
  articleId String  @unique
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@map("article_seo")
}

//
// author.prisma
//

model Author {
  id         String  @id @default(cuid())
  name       String
  slug       String  @unique
  image      String?
  bio        String? @db.Text
  websiteUrl String?

  // Sosial Media
  twitter   String?
  instagram String?
  facebook  String?
  linkedIn  String?

  // Relations
  articles Article[]
  websites Website[]

  // Jika setiap Author terhubung ke satu User (opsional)
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("author")
}

//
// enum.prisma
//

enum Role {
  USER
  ADMIN
  EDITOR
}

enum WebsiteStatus {
  PUBLISHED
  DRAFT
  MAINTENANCE
}

enum ArticleStatus {
  INITIAL
  DRAFT
  PUBLISHED
  ARCHIVED
  BUILDING
  FAILED
  WAITING_IMAGE
  QUEUED
}

enum TwitterCard {
  summary
  summary_large_image
  app
  player
}

enum RobotsValue {
  index_follow     @map("index, follow")
  noindex_follow   @map("noindex, follow")
  index_nofollow   @map("index, nofollow")
  noindex_nofollow @map("noindex, nofollow")
}

enum OgType {
  website
  article
  profile
  book
  video_movie
  video_episode
}

//
// session.prisma
//

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

//
// template.prisma
//

model Template {
  id            String    @id @default(cuid())
  name          String
  slug          String    @unique
  thumbnail     String?
  defaultConfig Json?
  websites      Website[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

//
// user.prisma
//

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  role Role @default(USER)

  sessions      Session[]
  accounts      Account[]
  websites      Website[]
  articles      Article[] @relation("ArticleCreator")
  authorProfile Author?

  @@map("user")
}

//
// verification.prisma
//

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

//
// website.prisma
//

model Website {
  id            String   @id @default(cuid())
  name          String
  domain        String   @unique
  logoSquare    String?
  logoRectangle String?
  favicon       String?
  language      String   @default("en")
  templateId    String
  template      Template @relation(fields: [templateId], references: [id])
  themeConfig   Json?

  // SEO Relation (1-to-1)
  seo WebsiteSeo?

  googleAnalyticsId String?
  ownerId           String
  owner             User          @relation(fields: [ownerId], references: [id])
  status            WebsiteStatus @default(DRAFT)

  // Relations
  articles Article[]
  authors  Author[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([templateId])
}

//
// websiteseo.prisma
//

model WebsiteSeo {
  id String @id @default(cuid())

  // Basic SEO
  title        String?
  description  String? @db.Text
  keywords     String? // Disimpan sebagai string koma (comma-separated)
  author       String?
  robots       String? @default("index, follow")
  canonicalUrl String? // Untuk link rel="canonical"

  // Open Graph (Facebook, LinkedIn)
  ogTitle       String?
  ogDescription String? @db.Text
  ogImage       String?
  ogUrl         String?
  ogType        String? @default("website")

  // Twitter Cards
  twitterCard        String? @default("summary_large_image")
  twitterTitle       String?
  twitterDescription String? @db.Text
  twitterImage       String?
  twitterHandle      String? // Misal: @username

  // Relation to Website
  websiteId String  @unique
  website   Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@map("website_seo")
}
