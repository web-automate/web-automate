model AiConfiguration {
  id          String   @id @default(cuid())
  provider    String   @unique // Contoh: 'anthropic', 'openai', 'gemini'
  apiKey      String   // Simpan encrypted jika memungkinkan
  baseUrl     String?  // Untuk provider yang menggunakan custom endpoint/proxy
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("ai_configurations")
}