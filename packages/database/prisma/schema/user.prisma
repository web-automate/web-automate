model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  role          Role      @default(USER)
  
  sessions      Session[]
  accounts      Account[]
  websites      Website[]
  articles      Article[] @relation("ArticleCreator")
  authorProfile Author?

  @@map("user")
}