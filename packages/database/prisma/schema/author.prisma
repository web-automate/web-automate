model Author {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  image       String?
  bio         String?  @db.Text
  websiteUrl  String?
  
  // Sosial Media
  twitter     String?
  instagram   String?
  facebook    String?
  linkedIn    String?
  
  // Relations
  articles    Article[]
  websites    Website[]
  
  // Jika setiap Author terhubung ke satu User (opsional)
  userId      String?   @unique
  user        User?     @relation(fields: [userId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("author")
}