{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "es2015",
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": true,
    "declarationMap": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "index.ts",
    "generated/prisma/index.d.ts",
    "generated/prisma/models.ts",
    "generated/prisma/client.ts",
    "generated/prisma/**/*.ts",
    "prisma/seed.ts"
  ],
  "exclude": ["node_modules", "dist"]
}