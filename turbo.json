{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "db:gen": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^db:gen"]
    },
    "build": {
      "cache": false,
      "dependsOn": ["^db:gen"],
      "outputs": [".next/**", "dist/**"]
    }
  }
}