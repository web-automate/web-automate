{
  "name": "scraper",
  "version": "1.0.0",
  "description": "scraper to gemini",
  "main": "src/index.ts",
  "scripts": {
    "test": "dotenv tsx src/index.ts",
    "dev": "nodemon --exec tsx src/index.ts",
    "build": "tsc",
    "build:css": "npx @tailwindcss/cli -i ./src/lib/html/assets/css/input.css -o ./src/lib/html/assets/css/style.css --minify",
    "start": "dotenv node dist/index.js",
    "swagger": "tsx src/config/swagger-gen.ts",
    "session": "dotenv tsx src/config/prepare_session.ts",
    "type-check": "tsc --noEmit"
  },
  "author": "misbakhul munir",
  "license": "ISC",
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.4.0",
    "@aws-sdk/client-s3": "^3.983.0",
    "@aws-sdk/s3-request-presigner": "^3.983.0",
    "@tailwindcss/cli": "^4.1.18",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/jsonwebtoken": "^9.0.10",
    "amqplib": "^0.10.9",
    "axios": "^1.13.2",
    "chrome-launcher": "^1.2.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "form-data": "^4.0.5",
    "fs-extra": "^11.3.3",
    "glob": "^13.0.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "postcss": "^8.5.6",
    "puppeteer": "^24.35.0",
    "puppeteer-core": "^24.35.0",
    "sharp": "^0.34.5",
    "swagger-autogen": "^2.23.7",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tailwindcss": "^4.1.18",
    "uuid": "^13.0.0",
    "v8": "^0.1.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.8",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/fs-extra": "^11.0.4",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.0.10",
    "@types/node-cron": "^3.0.11",
    "@types/swagger-jsdoc": "^6.0.4",
